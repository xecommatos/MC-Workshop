<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confissões UMinho</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0f0f13;
      color: #e2e2e8;
      min-height: 100vh;
    }

    header {
      background: #17171f;
      border-bottom: 1px solid #2a2a38;
      padding: 18px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    header h1 {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #fff;
    }

    header h1 span {
      color: #7c6af7;
    }

    .search-form {
      display: flex;
      gap: 8px;
    }

    .search-form input {
      background: #0f0f13;
      border: 1px solid #2a2a38;
      border-radius: 8px;
      padding: 8px 14px;
      color: #e2e2e8;
      font-size: 0.875rem;
      width: 220px;
      outline: none;
      transition: border-color 0.15s;
    }

    .search-form input:focus { border-color: #7c6af7; }

    .search-form button {
      background: #7c6af7;
      border: none;
      border-radius: 8px;
      padding: 8px 16px;
      color: #fff;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }

    .search-form button:hover { background: #6b58e8; }

    .main {
      max-width: 680px;
      margin: 0 auto;
      padding: 32px 24px;
    }

    /* Submit card */
    .submit-card {
      background: #17171f;
      border: 1px solid #2a2a38;
      border-radius: 14px;
      padding: 24px;
      margin-bottom: 32px;
    }

    .submit-card h2 {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #7c6af7;
      margin-bottom: 16px;
    }

    .submit-card textarea {
      width: 100%;
      background: #0f0f13;
      border: 1px solid #2a2a38;
      border-radius: 8px;
      padding: 12px 14px;
      color: #e2e2e8;
      font-size: 0.95rem;
      font-family: inherit;
      resize: vertical;
      min-height: 90px;
      outline: none;
      transition: border-color 0.15s;
    }

    .submit-card textarea:focus { border-color: #7c6af7; }

    .submit-row {
      display: flex;
      gap: 10px;
      margin-top: 10px;
      align-items: center;
    }

    .submit-row input {
      flex: 1;
      background: #0f0f13;
      border: 1px solid #2a2a38;
      border-radius: 8px;
      padding: 10px 14px;
      color: #e2e2e8;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.15s;
    }

    .submit-row input:focus { border-color: #7c6af7; }

    .submit-row button {
      background: #7c6af7;
      border: none;
      border-radius: 8px;
      padding: 10px 22px;
      color: #fff;
      font-size: 0.875rem;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s;
    }

    .submit-row button:hover { background: #6b58e8; }

    /* Feed */
    .feed-label {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #555570;
      margin-bottom: 16px;
    }

    .empty {
      color: #555570;
      font-size: 0.95rem;
      text-align: center;
      padding: 48px 0;
    }

    .confession-card {
      background: #17171f;
      border: 1px solid #2a2a38;
      border-radius: 14px;
      padding: 20px 22px;
      margin-bottom: 14px;
      transition: border-color 0.15s;
    }

    .confession-card:hover { border-color: #3a3a52; }

    .confession-text {
      font-size: 0.975rem;
      line-height: 1.65;
      color: #e2e2e8;
      margin-bottom: 12px;
    }

    .confession-meta {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .tag {
      background: #7c6af720;
      color: #9d90f8;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 20px;
      border: 1px solid #7c6af730;
    }

    .timestamp {
      font-size: 0.75rem;
      color: #555570;
    }
  </style>
</head>
<body>

<header>
  <h1>Confissões <span>UMinho</span></h1>
  <form class="search-form" action="/" method="GET">
    <input type="text" name="q" value="<%= q %>" placeholder="Pesquisar...">
    <button type="submit">Pesquisar</button>
  </form>
</header>

<div class="main">
  <div class="submit-card">
    <h2>Nova Confissão</h2>
    <form action="/confessions" method="POST">
      <textarea name="text" placeholder="Confessa aqui..." required></textarea>
      <div class="submit-row">
        <input type="text" name="tag" placeholder="Curso / Cadeira" required>
        <button type="submit">Confessar</button>
      </div>
    </form>
  </div>

  <div class="feed-label">Feed</div>

  <% if (confessions.length === 0) { %>
    <p class="empty">Nenhuma confissão ainda.</p>
  <% } else { %>
    <% confessions.forEach(function(confession) { %>
      <div class="confession-card">
        <div class="confession-text"><%- confession.text %></div>
        <div class="confession-meta">
          <span class="tag"><%= confession.tag %></span>
          <span class="timestamp"><%= confession.created_at %></span>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

</body>
</html>
